{
  "name": "NIR2FPGA — iscas26 Tutorial",
  "image": "ghcr.io/tommyck003/nir2fpga-iscas:latest",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "mounts": [
    "source=nir2fpga-devenv,target=${containerWorkspaceFolder}/.devenv,type=volume",
    "source=nir2fpga-coursier,target=/home/vscode/.cache/coursier,type=volume",
    "source=nir2fpga-sbt,target=/home/vscode/.sbt,type=volume",
    "source=nir2fpga-ivy2,target=/home/vscode/.ivy2,type=volume",
    "source=nir2fpga-pip,target=/home/vscode/.cache/pip,type=volume"
  ],
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "forwardPorts": [8888],
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.devenv/state/venv/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n",
        "files.autoGuessEncoding": false,
        "autoOpen.files": [
          "iscas26-tutorial/neuron/1-definition.ipynb",
          "iscas26-tutorial/neuron/2-n2f.ipynb"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.jupyter-keymap",
        "mkhl.direnv",
        "jnoortheen.nix-ide",
        "simonw.auto-open"
      ],
      "extensionsDisabled": [
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
