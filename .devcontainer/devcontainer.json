{
  "name": "NIR2FPGA — minimal",
  "image": "nir2fpga:phase1",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8888],
  "customizations": {
    "vscode": {
      "settings": {
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
